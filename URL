### 1. scout.py | Signal Isolation
```python
from bs4 import BeautifulSoup

def get_high_signal_container(html: str, min_chars: int = 50, aria_multiplier: float = 2.0):
    try:
        soup = BeautifulSoup(html, 'lxml')
        candidates = []
        for container in soup.find_all(['main', 'section', 'article', 'div', 'table']):
            text = container.get_text(strip=True)
            if len(text) < min_chars: continue
            tag_count = max(len(container.find_all()), 1)
            density = len(text) / tag_count
            link_ratio = sum(len(a.get_text(strip=True)) for a in container.find_all('a')) / max(len(text), 1)
            bonus = aria_multiplier if container.get('role') == 'main' else 1.0
            score = (density * bonus) / (link_ratio + 1)
            candidates.append({'node': container, 'score': score})
        return sorted(candidates, key=lambda x: x['score'], reverse=True)[0]['node']
    except Exception: return None

```
### 2. surgeon.py | Field Extraction
```python
from bs4 import BeautifulSoup

def extract_fields(html_node, archetype_selectors=None):
    soup = BeautifulSoup(str(html_node), 'html.parser')
    res = {'title': None, 'date': None, 'content': None, 'method': 'INITIALIZED'}
    if archetype_selectors:
        for field, selector in archetype_selectors.items():
            found = soup.select_one(selector)
            if found:
                res[field] = found.get_text(strip=True)
                res['method'] = 'VERIFIED'
    if not res['content']:
        blocks = soup.find_all(['p', 'div', 'span'])
        if blocks:
            res['content'] = max([b.get_text(strip=True) for b in blocks], key=len)
            res['method'] = 'HEURISTIC'
    return res

```
### 4. taxonomy.py | Semantic Classification
```python
import re

class TaxonomyEngine:
    def __init__(self, schema: dict = None):
        self.schema = schema or {}
    def classify(self, text: str):
        if not text: return {}
        clean_text = text.lower()
        results = {}
        for category, patterns in self.schema.items():
            hits = sum(len(re.findall(p, clean_text, re.I)) for p in patterns)
            strength = round((hits / max(len(clean_text), 1)) * 1000, 2)
            if hits > 0:
                results[category] = {"hits": hits, "strength": strength}
        return results

```
### 6. archivist.py | Persistence
```python
import json, os, uuid
from datetime import datetime

def persist(data_package, root_dir='vault/', prefix='SHER'):
    if not os.path.exists(root_dir): os.makedirs(root_dir)
    date_str = data_package.get('iso', datetime.now().isoformat())[:10]
    filename = f"{date_str}_{prefix}-{str(uuid.uuid4())[:4]}.json"
    file_path = os.path.join(root_dir, filename)
    with open(file_path, 'w', encoding='utf-8') as f:
        json.dump(data_package, f, indent=4, ensure_ascii=False)
    return file_path

```
